      "TurretLegacy",
      "Eden_TurretSlowDamage",
      "Eden_TurretOrganicAlienBeam",
      "FoundationBlocks"
    ],

    "_comment_desc": "Items/Blocks that have any top-level property value containing any of these substrings (case-sensitive) are silently dropped.",
